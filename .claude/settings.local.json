{
  "permissions": {
    "defaultMode": "default",
    "deny": [
      "Bash(rm -rf *)",
      "Bash(git push --force *)",
      "Read(**/.env*)",
      "Edit(**/.env*)"
    ],
    "ask": [
      "Bash(npm publish)",
      "Bash(docker *)",
      "Bash(git commit *)",
      "Bash(git push *)",
      "Bash(aws *)"
    ],
    "allow": [
      "Read",
      "Edit",
      "Write",
      "WebFetch",
      "Bash(git status)",
      "Bash(git diff *)",
      "mcp__brave_search__*",
      "mcp__tavily__*"
    ]
  }
}